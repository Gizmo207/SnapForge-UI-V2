# SnapForge UI v2 — environment template. Copy to .env.local and fill in.
#
# Multi-user: every signed-in account gets its own isolated vault. There is no
# single-owner OWNER_ID anymore — identity comes from the verified session and
# data is scoped per user.

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# At least one OAuth provider. Each is enabled only if both of its vars are set.
# GitHub OAuth app:  https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=
# Google OAuth client: https://console.cloud.google.com/apis/credentials
GOOGLE_ID=
GOOGLE_SECRET=

# Supabase (server-side only — never expose the service role key to the client)
SUPABASE_URL=https://ojuzilqrhoaquxkedxpd.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
