# SnapForge UI v2 — environment template. Copy to .env.local and fill in.

# The single owner the vault is bound to (the provider subject id of the owner).
OWNER_ID=

# Auth.js / NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# Supabase (server-side only — never expose the service role key to the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
